# Database
DATABASE_URL=postgresql+asyncpg://codeatlas:dev_password@postgres:5432/codeatlas_dev

# Vector Database (Qdrant)
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Google AI Studio (https://aistudio.google.com/apikey)
# Used for: gemini-embedding-001 embeddings (required) + Gemini LLM fallback
GOOGLE_API_KEY=your_google_ai_studio_api_key

# Groq (https://console.groq.com/keys) — optional but recommended for Q&A
# When set, Groq is used for all LLM calls (Q&A + reranking); Gemini is fallback.
# Free tier: 14,400 RPD, 30 RPM — far more generous than Gemini free tier.
GROQ_API_KEY=

# GitHub OAuth (https://github.com/settings/developers → OAuth Apps)
# Dev App callback URL: http://localhost:3000/callback
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# JWT
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_very_long_random_secret_key_at_least_32_characters

# Application
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=INFO
